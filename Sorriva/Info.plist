<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Sorriva needs access to your local network to discover and control Sonos and Bluesound speakers.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_sonos._tcp</string>
        <string>_musc._tcp</string>
        <string>_musp._tcp</string>
        <string>_musz._tcp</string>
        <string>_mush._tcp</string>
        <string>_smb._tcp</string>
    </array>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
